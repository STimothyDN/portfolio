# Public CDN base URL for the Bunny.net Pull Zone serving photography images.
# Used by the Astro site at build time.
PUBLIC_BUNNY_CDN_URL=https://<pull-zone>.b-cdn.net

# Bunny.net Storage credentials, used only by scripts/upload-shoot.mjs.
# Find these in the Bunny dashboard under your Storage Zone's FTP & API Access tab.
# BUNNY_STORAGE_ACCESS_KEY is the storage zone password, NOT your account API key.
BUNNY_STORAGE_ZONE=<storage-zone-name>
BUNNY_STORAGE_REGION=
BUNNY_STORAGE_ACCESS_KEY=<storage-zone-password>
