---
import { getCollection } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import Hero from '../../components/Hero.astro';

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout title="Blog | Timothy Navarro" description="Thoughts, tutorials, and updates from Timothy Navarro">
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Blog"
				tagline="Thoughts, tutorials, and things I'm working on."
				align="start"
			/>
			<section class="posts" data-animate-group data-stagger="0.1">
				{posts.length === 0 && <p class="empty">No posts yet — check back soon!</p>}
				{posts.map((post) => (
					<article class="post-card">
						<a href={`/blog/${post.slug}/`}>
							<h3 class="post-title">{post.data.title}</h3>
							<p class="post-description">{post.data.description}</p>
							<div class="post-meta">
								<time datetime={post.data.publishDate.toISOString()}>
									{post.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
								</time>
								<div class="post-tags">
									{post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
								</div>
							</div>
						</a>
					</article>
				))}
			</section>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.posts {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.empty {
		color: var(--gray-400);
		font-size: var(--text-lg);
	}

	.post-card {
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		background: var(--gradient-subtle);
		box-shadow: var(--shadow-sm);
		transition: box-shadow var(--theme-transition);
	}

	.post-card:hover {
		box-shadow: var(--shadow-md);
	}

	.post-card a {
		display: block;
		padding: 1.5rem;
		text-decoration: none;
		color: inherit;
	}

	.post-title {
		font-size: var(--text-xl);
		color: var(--gray-0);
		margin-bottom: 0.5rem;
	}

	.post-description {
		color: var(--gray-300);
		font-size: var(--text-md);
		margin-bottom: 1rem;
	}

	.post-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 1rem;
		font-size: var(--text-sm);
		color: var(--gray-400);
	}

	.post-tags {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.tag {
		padding: 0.25rem 0.75rem;
		border-radius: 999rem;
		background-color: var(--gray-800);
		color: var(--gray-300);
		font-size: var(--text-sm);
	}

	@media (min-width: 50em) {
		.post-card a {
			padding: 2rem;
		}

		.post-title {
			font-size: var(--text-2xl);
		}
	}
</style>
