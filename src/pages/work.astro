---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';

import ContactCTA from '../components/ContactCTA.astro';
import WorkIndexRow from '../components/WorkIndexRow.astro';
import Hero from '../components/Hero.astro';

const projects = (await getCollection('work')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<BaseLayout
	title="My Work | Timothy Navarro"
	description="Learn about Timothy Navarro's most recent projects"
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="My Work"
				tagline="See some of the projects I've worked on below to get an idea of my past experience."
				align="start"
			/>
			<ol class="work-index">
				{
					projects.map((project, i) => (
						<li data-animate="work-row">
							<WorkIndexRow project={project} index={i} eager={i === 0} />
						</li>
					))
				}
			</ol>
		</main>
		<ContactCTA />
	</div>

	<!-- Cursor-follow preview (work-hover.ts). Decorative duplicate of the
	     hovered row's thumb, so it stays hidden from the a11y tree. -->
	<figure class="work-float" aria-hidden="true">
		<img alt="" width="480" height="320" />
	</figure>
</BaseLayout>

<style>
	.work-index {
		list-style: none;
		margin: 0;
		padding: 0;
		border-bottom: 1px solid var(--gray-800);
	}

	.work-float {
		display: none;
		position: fixed;
		top: 0;
		left: 0;
		z-index: 6;
		margin: 0;
		width: min(26rem, 40vw);
		aspect-ratio: 3 / 2;
		border-radius: 1rem;
		overflow: hidden;
		border: 1px solid var(--gray-800);
		box-shadow: var(--shadow-lg);
		pointer-events: none;
		opacity: 0;
	}

	.work-float img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	@media (min-width: 50em) and (pointer: fine) and (prefers-reduced-motion: no-preference) {
		.work-float {
			display: block;
		}
	}
</style>

<script>
	import '../scripts/work-hover';
</script>
