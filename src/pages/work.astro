---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';

import ContactCTA from '../components/ContactCTA.astro';
import WorkIndexRow from '../components/WorkIndexRow.astro';
import Hero from '../components/Hero.astro';

const projects = (await getCollection('work')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<BaseLayout
	title="My Work | Timothy Navarro"
	description="Learn about Timothy Navarro's most recent projects"
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="My Work"
				tagline="See some of the projects I've worked on below to get an idea of my past experience."
				align="start"
			/>
			<ol class="work-index">
				{
					projects.map((project, i) => (
						<li data-animate="work-row">
							<WorkIndexRow project={project} eager={i === 0} />
						</li>
					))
				}
			</ol>
		</main>
		<ContactCTA />
	</div>

	<!-- Cursor-follow preview (work-hover.ts). Decorative duplicate of the
	     hovered row's thumb, so it stays hidden from the a11y tree. -->
	<figure class="work-float" aria-hidden="true">
		<img alt="" width="480" height="320" />
		<figcaption class="work-float-overlay"></figcaption>
	</figure>
</BaseLayout>

<style>
	.work-index {
		list-style: none;
		margin: 0;
		padding: 0;
		border-bottom: 1px solid var(--gray-800);
	}

	.work-float {
		display: none;
		position: fixed;
		top: 0;
		left: 0;
		z-index: 6;
		margin: 0;
		width: min(34rem, 46vw);
		aspect-ratio: 3 / 2;
		border-radius: 0.5rem;
		overflow: hidden;
		border: 1px solid var(--gray-800);
		box-shadow: var(--shadow-lg);
		pointer-events: none;
		opacity: 0;
		background: var(--gray-999);
	}

	.work-float img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.work-float::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, rgb(0 0 0 / 0.16), rgb(0 0 0 / 0.78));
		pointer-events: none;
	}

	.work-float-overlay {
		position: absolute;
		inset: auto 0 0;
		z-index: 1;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: clamp(1rem, 2vw, 1.4rem);
		color: white;
		text-shadow: 0 1px 1.5rem rgb(0 0 0 / 0.45);
	}

	.work-float-overlay :global(.preview-year) {
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		font-variant-numeric: tabular-nums;
		color: rgb(255 255 255 / 0.72);
	}

	.work-float-overlay :global(.preview-tags) {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.work-float-overlay :global(.preview-tags span) {
		display: inline-flex;
		align-items: center;
		min-height: 1.85rem;
		padding: 0.3rem 0.65rem;
		border: 1px solid rgb(255 255 255 / 0.32);
		border-radius: 999rem;
		background: rgb(0 0 0 / 0.28);
		font-size: var(--text-sm);
		line-height: 1.2;
		backdrop-filter: blur(10px);
	}

	.work-float-overlay :global(.preview-description) {
		display: -webkit-box;
		overflow: hidden;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 3;
		max-width: 52ch;
		font-size: var(--text-md);
		line-height: 1.45;
		color: rgb(255 255 255 / 0.9);
	}

	@media (min-width: 50em) and (pointer: fine) and (prefers-reduced-motion: no-preference) {
		.work-float {
			display: block;
		}
	}
</style>

<script>
	import '../scripts/work-hover';
</script>
