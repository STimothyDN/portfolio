---
import { getCollection } from 'astro:content';

// Layout import — provides basic page elements: <head>, <nav>, <footer> etc.
import BaseLayout from '../layouts/BaseLayout.astro';

// Component Imports
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';

// Page section components
import ContactCTA from '../components/ContactCTA.astro';
import Skills from '../components/Skills.astro';

// Content Fetching: List four most recent work projects
const projects = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 4);

// Full Astro Component Syntax:
// https://docs.astro.build/core-concepts/astro-components/
---

<BaseLayout>
	<div class="stack gap-10 lg:gap-20">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero">
				<Hero
					title="Timothy Navarro."
					tagline="I am a Full Stack Software Developer currently based in Research Triangle Park, North Carolina"
					align="start"
					size="display"
					brandSwap={{ keep: 'Timo', swapOut: 'thy', swapIn: '3' }}
				>
					<div class="roles" data-animate-group data-stagger="0.07" data-animate-delay="0.6">
						<a href="/work"><Pill><Icon icon="code" size="1.33em" /> Developer</Pill></a>
						<a href="https://soundcloud.com/timo_on_duty" target="_blank" rel="noopener"><Pill><Icon icon="producer" size="1.33em" /> Producer</Pill></a>
						<a href="/photography/"><Pill><Icon icon="camera" size="1.33em" /> Photographer</Pill></a>
						<a href="https://docs.google.com/document/d/1It_OJS21vwgpbcy6P4QIGzRIacEXh6JH8Os51Dc4qtc/edit?usp=sharing" target="_blank" rel="noopener"><Pill><Icon icon="cook" size="1.33em" /> Home Cook</Pill></a>
					</div>
				</Hero>

				<div class="portrait" data-animate="clip" data-parallax="0.07">
					<img
						alt="Headshot of Timothy Navarro smiling in a light blue collared shirt, in a bright columned hallway"
						width="480"
						height="620"
						src="/assets/timothy.jpeg"
					/>
				</div>
			</header>

			<Skills />
		</div>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	.roles {
		display: none;
	}

	.roles a {
		text-decoration: none;
	}

	.portrait img {
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: top;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	/* Slow idle float on the headshot — decorative only */
	@media (prefers-reduced-motion: no-preference) {
		.portrait img {
			animation: portrait-float 7s ease-in-out infinite alternate;
		}

		@keyframes portrait-float {
			from {
				transform: translateY(-4px);
			}
			to {
				transform: translateY(6px);
			}
		}
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
		}

		.roles {
			margin-top: 0.5rem;
			display: flex;
			flex-wrap: wrap;
			gap: 0.5rem;
		}

		.portrait img {
			aspect-ratio: 3 / 4;
			border-radius: 4.5rem;
			object-fit: cover;
		}
	}

</style>
