---
import { getCollection } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';

import ContactCTA from '../../components/ContactCTA.astro';
import ShootCover from '../../components/ShootCover.astro';
import ShootPanel from '../../components/ShootPanel.astro';
import PhotoLightbox from '../../components/PhotoLightbox.vue';
import PhotographyGlobe from '../../components/PhotographyGlobe.vue';
import { bunnyImageUrl } from '../../utils/bunny';
import { toLightboxPhotos } from '../../utils/lightbox';

const shoots = (await getCollection('photography')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// One lightbox serves every inline shoot panel; open-lightbox events carry the
// shoot slug that selects the active photo set.
const photoSets = Object.fromEntries(
	shoots.map((shoot) => [shoot.id, toLightboxPhotos(shoot.id, shoot.data.photos)])
);

// Collect every photo coordinate across all shoots, deduped to one pin per
// unique location (rounded to ~11m). Many photos in a shoot share a coordinate,
// so this keeps the globe from rendering dozens of stacked pins. Each pin also
// carries a handful of sample thumbnails taken at that location — the globe
// picks one at random to preview when the pin is hovered.
const MAX_SAMPLES_PER_PIN = 10;
type GlobePin = { lat: number; lon: number; name?: string; images: string[] };
const pinMap = new Map<string, GlobePin>();
for (const shoot of shoots) {
	for (const photo of shoot.data.photos) {
		const loc = photo.location;
		if (!loc || loc.latitude === undefined || loc.longitude === undefined) continue;
		const lat = Math.round(loc.latitude * 1e4) / 1e4;
		const lon = Math.round(loc.longitude * 1e4) / 1e4;
		const key = `${lat},${lon}`;
		let pin = pinMap.get(key);
		if (!pin) {
			pin = { lat, lon, name: loc.name, images: [] };
			pinMap.set(key, pin);
		}
		if (pin.images.length < MAX_SAMPLES_PER_PIN) {
			pin.images.push(bunnyImageUrl(shoot.id, photo.filename, { width: 440, quality: 72, format: 'webp' }));
		}
	}
}
const globePins: GlobePin[] = [...pinMap.values()];
---

<BaseLayout
	title="Photography | Timothy Navarro"
	description="A collection of photo shoots by Timothy Navarro"
>
	<div class="stack gap-20">
		<div class="photography-page stack" data-photo-snap-root>
			<header class="photography-landing" data-photo-landing>
				<PhotographyGlobe client:idle pins={globePins} />
				<div class="landing-veil"></div>
			</header>
			<main class="shoot-stage" data-photo-stage>
				<div class="stage-header" data-photo-title>
					<div class="wrapper">
						<a class="stage-back" href="/photography/" data-panel-close>Back to all shoots</a>
						<h1>Timo From 3,</h1>
						<p class="tagline">He shoots! He-</p>
					</div>
				</div>
				<div class="wrapper stage-body">
					<ul class="shoot-index" data-shoot-list>
						{
							shoots.map((shoot, i) => (
								<li>
									<ShootCover shoot={shoot} eager={i === 0} />
								</li>
							))
						}
					</ul>
					<aside class="shoot-preview" data-shoot-preview aria-hidden="true">
						<div class="preview-frame">
							<div class="preview-parallax">
								<img class="preview-buf" alt="" width="720" height="480" decoding="async" />
								<img class="preview-buf" alt="" width="720" height="480" decoding="async" />
							</div>
						</div>
						<p class="preview-meta">
							<span data-preview-index>01</span>
							<span class="preview-rule"></span>
							<span data-preview-total>{String(shoots.length).padStart(2, '0')}</span>
						</p>
					</aside>
					{shoots.map((shoot) => <ShootPanel shoot={shoot} />)}
					<PhotoLightbox client:load photoSets={photoSets} />
				</div>
			</main>
		</div>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	/*
	 * Soft section snapping happens on the page scroller (not a nested overflow
	 * box, which fought the page scroll on mobile). `proximity` only eases
	 * toward a section when the scroll rests near it — never mid-gesture.
	 * Note: base.css gives html and body `height: 100%; overflow-x: hidden`,
	 * which makes <body> the element that actually scrolls — so the snap type
	 * lives there (html included in case that ever changes).
	 */
	:global(html[data-section='photography']),
	:global(html[data-section='photography'] body) {
		scroll-snap-type: y proximity;
	}

	.photography-page {
		/*
		 * Both vars are refined at runtime by photo-section-snap.ts; these are
		 * no-JS approximations. --photo-landing-offset is the chrome above the
		 * landing (nav + its margin); --photo-title-h is the docked title
		 * block's natural height (headline + tagline + padding).
		 */
		--photo-landing-offset: 7.5rem;
		--photo-title-h: calc(clamp(3.5rem, 10vw, 8rem) * 0.88 + 9rem);
		gap: 0;
	}

	.photography-landing {
		position: relative;
		z-index: 0;
		height: calc(100svh - var(--photo-landing-offset));
		overflow: hidden;
		background: var(--gray-999);
		scroll-snap-align: start;
		/* Snap the landing back to the true top of the page, nav included. */
		scroll-margin-top: var(--photo-landing-offset);
		scroll-snap-stop: always;
	}

	/*
	 * The "slit" the globe tucks into: an opaque band matching the page
	 * background, sitting above the globe canvas but below the title text, so
	 * the bottom ~quarter of the Earth disappears into the page.
	 */
	.landing-veil {
		position: absolute;
		inset: auto 0 0 0;
		height: 30%;
		z-index: 1;
		background: var(--gray-999);
		box-shadow: 0 -1px 0 var(--gray-800);
	}

	/*
	 * The stage is pulled up over the landing by the title block's height, so
	 * the title starts docked at the bottom of the first viewport, sitting on
	 * the veil. Scrolling carries it to the top, where it pins (sticky) and the
	 * grid slides underneath.
	 */
	.shoot-stage {
		position: relative;
		z-index: 1;
		min-height: 100svh;
		margin-top: calc(-1 * var(--photo-title-h));
		scroll-snap-align: start;
		scroll-snap-stop: always;
	}

	/* While a shoot panel is open the view rests below the masthead's stick
	   threshold; without this, proximity snapping would drag it back to the
	   stage top and un-condense the masthead (photo-shoot-expand.ts). */
	.photography-page[data-shoot-open] .shoot-stage {
		scroll-snap-align: none;
	}

	/*
	 * The single title block: masthead-sized while docked, compact once pinned
	 * (`.is-stuck`, toggled by photo-section-snap.ts). One element for both
	 * states — no duplicate title to catch mid-snap.
	 */
	.stage-header {
		position: sticky;
		top: 0;
		z-index: 4;
		padding-block: clamp(1.25rem, 3vw, 2rem) clamp(1.5rem, 4vw, 3rem);
		background: var(--gray-999);
		border-bottom: 1px solid transparent;
		overflow-anchor: none;
	}

	.stage-header.is-stuck {
		padding-block: clamp(0.75rem, 2vw, 1.25rem);
		border-bottom-color: var(--gray-800);
	}

	.stage-back {
		display: none;
		align-items: center;
		gap: 0.4rem;
		margin-bottom: 0.5rem;
		color: var(--gray-300);
		font-size: var(--text-sm);
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition:
			color var(--theme-transition),
			text-decoration-color var(--theme-transition);
	}

	.photography-page[data-shoot-open] .stage-back {
		display: inline-flex;
	}

	.stage-back:hover,
	.stage-back:focus-visible {
		color: var(--gray-0);
		text-decoration-color: currentColor;
	}

	h1 {
		max-width: 13ch;
		line-height: 0.88;
		color: var(--gray-0);
		font-size: clamp(3.5rem, 10vw, 8rem);
		/* Same cut as the shoot titles in the index list (upright Fraunces),
		 * overriding the italic SOFT/WONK masthead treatment from base.css —
		 * this block is unlayered, so it wins over @layer base. */
		font-style: normal;
		font-weight: 600;
		font-variation-settings: 'opsz' 40;
		letter-spacing: -0.01em;
	}

	.is-stuck h1 {
		font-size: var(--text-2xl);
	}

	.tagline {
		max-width: 58ch;
		margin-top: clamp(0.75rem, 2vw, 1.25rem);
		padding-top: clamp(0.75rem, 2vw, 1.25rem);
		border-top: 1px solid var(--gray-800);
		font-size: var(--text-lg);
		font-style: italic;
		color: var(--gray-200);
	}

	.is-stuck .tagline {
		margin-top: 0.35rem;
		padding-top: 0;
		border-top-color: transparent;
		font-size: var(--text-md);
		color: var(--gray-300);
	}

	@media (prefers-reduced-motion: no-preference) {
		.stage-header {
			transition:
				padding 450ms cubic-bezier(0.33, 1, 0.68, 1),
				border-color 450ms ease;
		}

		h1 {
			transition: font-size 450ms cubic-bezier(0.33, 1, 0.68, 1);
		}

		.tagline {
			transition:
				font-size 450ms cubic-bezier(0.33, 1, 0.68, 1),
				margin-top 450ms cubic-bezier(0.33, 1, 0.68, 1),
				padding-top 450ms cubic-bezier(0.33, 1, 0.68, 1),
				border-color 450ms ease,
				color 450ms ease;
		}
	}

	/* photo-section-snap.ts sets this while reading the un-stuck height. */
	.stage-header[data-measuring],
	.stage-header[data-measuring] h1,
	.stage-header[data-measuring] .tagline {
		transition: none !important;
	}

	.stage-body {
		padding-block: clamp(2rem, 5vw, 3.5rem) clamp(3rem, 8vw, 6rem);
	}

	/* Narrower measure than the 83rem wrapper: gallery margins for the plates. */
	.shoot-index {
		list-style: none;
		margin: 0 auto;
		padding: 0;
		max-width: 68rem;
		display: flex;
		flex-direction: column;
		border-bottom: 1px solid var(--gray-800);
	}

	/* `display: flex` above would beat the UA [hidden] rule when a shoot panel
	   replaces the list (photo-shoot-expand.ts). */
	.shoot-index[hidden] {
		display: none;
	}

	/* Pinned preview stage — hidden by default; the fine-pointer media block
	 * below turns the stage body into a two-column layout with this pane
	 * sticky in the right rail. photo-hover.ts drives the image swaps. */
	.shoot-preview {
		display: none;
	}

	@media (min-width: 50em) {
		h1 {
			max-width: 14ch;
		}

		.photography-page {
			--photo-landing-offset: 9rem;
		}
	}

	@media (min-width: 50em) and (pointer: fine) and (prefers-reduced-motion: no-preference) and (scripting: enabled) {
		/* Typographic list left, pinned stage right. Rows (and their stretched
		 * link hit areas) now stop at the column edge instead of spanning the
		 * page, so moving the cursor around the page no longer grazes them.
		 * Reverts to a plain block while a shoot panel is open. */
		.photography-page:not([data-shoot-open]) .stage-body {
			display: grid;
			grid-template-columns: minmax(0, 1fr) clamp(20rem, 30vw, 26rem);
			gap: clamp(2.5rem, 5vw, 5rem);
			align-items: start;
		}

		.photography-page:not([data-shoot-open]) .shoot-index {
			grid-column: 1;
			grid-row: 1;
			max-width: none;
			margin: 0;
		}

		.photography-page:not([data-shoot-open]) .shoot-preview {
			display: block;
			grid-column: 2;
			grid-row: 1;
			/* Clears the condensed sticky masthead (verified ~6.5rem tall). */
			position: sticky;
			top: clamp(7.5rem, 12vh, 9rem);
		}

		.preview-frame {
			position: relative;
			aspect-ratio: 3 / 2;
			overflow: hidden;
			border: 1px solid var(--gray-800);
			background: var(--gray-900);
			box-shadow: var(--shadow-lg);
		}

		.preview-parallax {
			position: absolute;
			inset: 0;
			will-change: transform;
		}

		.preview-buf {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			object-fit: cover;
			opacity: 0;
			transform: scale(1.06);
			will-change: transform, clip-path;
		}

		.preview-meta {
			display: flex;
			align-items: center;
			gap: 0.85rem;
			margin-top: 0.85rem;
			font-size: var(--text-sm);
			letter-spacing: 0.08em;
			font-variant-caps: all-small-caps;
			color: var(--gray-300);
		}

		.preview-rule {
			flex: 1;
			height: 1px;
			background: var(--gray-800);
		}
	}
</style>

<script>
	import '../../scripts/photo-hover';
	import '../../scripts/photo-shoot-expand';
</script>
