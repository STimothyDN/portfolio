---
import { type CollectionEntry, getCollection } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';

import ContactCTA from '../../components/ContactCTA.astro';
import PhotoParentBar from '../../components/PhotoParentBar.astro';
import PhotoGrid from '../../components/PhotoGrid.astro';
import PhotoLightbox from '../../components/PhotoLightbox.vue';
import { toLightboxPhotos } from '../../utils/lightbox';

interface Props {
	entry: CollectionEntry<'photography'>;
}

export async function getStaticPaths() {
	const shoots = await getCollection('photography');
	return shoots.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { data, id } = entry;
const formattedDate = data.date.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
	timeZone: 'UTC',
});

const lightboxPhotos = toLightboxPhotos(id, data.photos);
---

<BaseLayout title={data.title} description={data.description ?? `Photos from ${data.title}`}>
	<div class="stack gap-20">
		<div class="shoot-page stack" data-photo-snap-root>
			<PhotoParentBar />
			<main class="photo-stage" data-photo-stage>
				<div class="stage-header" data-photo-title>
					<div class="wrapper">
						<h1>{data.title}</h1>
						<div class="details">
							<p class="meta">
								{formattedDate}
								{data.location && <> · {data.location}</>}
								 · {data.photos.length} photos
							</p>
							{
								data.description && (
									<div class="description-reveal">
										<div class="description-reveal-inner">
											<p class="description">{data.description}</p>
										</div>
									</div>
								)
							}
						</div>
					</div>
				</div>
				<div class="wrapper stage-body">
					<PhotoGrid shootSlug={id} photos={data.photos} />
					<PhotoLightbox client:load photos={lightboxPhotos} shootSlug={id} />
				</div>
			</main>
		</div>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	/*
	 * Nested shoot: a slim parent breadcrumb (PhotoParentBar) pins at the top and
	 * the shoot's own header pins directly beneath it (top: --photo-parent-bar-h,
	 * measured at runtime by photo-section-snap.ts). The header starts full-size
	 * and condenses to a compact bar (`.is-stuck`) as the section reaches the top
	 * — a two-tier sticky that makes browsing a shoot feel like a view within the
	 * photography app rather than a separate page.
	 */
	.shoot-page {
		/* Runtime-measured by photo-section-snap.ts; this is the no-JS fallback. */
		--photo-parent-bar-h: 2.75rem;
		gap: 0;
	}

	.photo-stage {
		position: relative;
		z-index: 1;
		min-height: 100svh;
	}

	.stage-header {
		position: sticky;
		top: var(--photo-parent-bar-h);
		z-index: 4;
		padding-block: clamp(1.5rem, 4vw, 2.75rem) clamp(1.5rem, 4vw, 3rem);
		background: var(--gray-999);
		border-bottom: 1px solid transparent;
	}

	.stage-header.is-stuck {
		padding-block: clamp(0.75rem, 2vw, 1.25rem);
		border-bottom-color: var(--gray-800);
	}

	h1 {
		max-width: 13ch;
		line-height: 0.9;
		letter-spacing: 0;
		color: var(--gray-0);
		font-size: clamp(3rem, 8vw, 6rem);
	}

	.is-stuck h1 {
		max-width: none;
		font-size: var(--text-2xl);
		line-height: 1.1;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.details {
		display: flex;
		flex-direction: column;
		max-width: 58ch;
		margin-top: clamp(0.75rem, 2vw, 1.25rem);
		padding-top: clamp(0.75rem, 2vw, 1.25rem);
		gap: 0.65rem;
		border-top: 1px solid var(--gray-800);
	}

	.is-stuck .details {
		margin-top: 0.35rem;
		padding-top: 0;
		gap: 0;
		border-top-color: transparent;
	}

	.meta {
		font-size: var(--text-md);
		letter-spacing: 0.06em;
		font-variant-caps: all-small-caps;
		/* --gray-400 fails 4.5:1 on the photography-light palette; --gray-300 clears it. */
		color: var(--gray-300);
	}

	.description-reveal {
		display: grid;
		grid-template-rows: 1fr;
		opacity: 1;
	}

	.description-reveal-inner {
		overflow: hidden;
		min-height: 0;
	}

	.is-stuck .description-reveal {
		grid-template-rows: 0fr;
		opacity: 0;
		visibility: hidden;
	}

	.description {
		font-size: var(--text-lg);
		max-width: 54ch;
	}

	@media (prefers-reduced-motion: no-preference) {
		.stage-header {
			transition:
				padding 450ms cubic-bezier(0.33, 1, 0.68, 1),
				border-color 450ms ease;
		}

		h1 {
			transition: font-size 450ms cubic-bezier(0.33, 1, 0.68, 1);
		}

		.details {
			transition:
				margin-top 450ms cubic-bezier(0.33, 1, 0.68, 1),
				padding-top 450ms cubic-bezier(0.33, 1, 0.68, 1),
				gap 450ms cubic-bezier(0.33, 1, 0.68, 1),
				border-color 450ms ease;
		}

		.description-reveal {
			transition:
				grid-template-rows 450ms cubic-bezier(0.33, 1, 0.68, 1),
				opacity 450ms ease,
				visibility 0s;
		}

		/* Keep the description visible until its collapse finishes. */
		.is-stuck .description-reveal {
			transition-delay: 0s, 0s, 450ms;
		}
	}

	/* photo-section-snap.ts sets this while reading the un-stuck height. */
	.stage-header[data-measuring],
	.stage-header[data-measuring] * {
		transition: none !important;
	}

	.stage-body {
		padding-block: clamp(2rem, 5vw, 3.5rem) clamp(3rem, 8vw, 6rem);
	}

	@media (min-width: 50em) {
		h1 {
			max-width: 14ch;
		}
	}
</style>
