---
// Learn about using Astro layouts:
// https://docs.astro.build/en/core-concepts/layouts/

// Component Imports
import MainHead from '../components/MainHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title?: string | undefined;
	description?: string | undefined;
}

const { title, description } = Astro.props;

// Which "world" is this page in? The photography section gets the editorial
// theme (see tokens.css `html[data-section="photography"]`). Computed server-side
// so the correct theme is applied on direct load / no-JS, and travels with each
// route's HTML across ClientRouter swaps.
const path = Astro.url.pathname;
const section =
	path === '/photography' || path.startsWith('/photography/') ? 'photography' : 'default';
---

<html lang="en" data-section={section}>
	<head>
		<MainHead title={title} description={description} />
	</head>
	<body>
		<!--
			The canvas element renders ambient sky effects: clouds in light mode and
			stars/meteors in dark mode. The page content is wrapped in .content so it appears above.
			The canvas is intentionally NOT persisted: on a section transition we want it
			captured in the View Transition snapshot so it drains away with the page.
		-->
		<div class="stack backgrounds">
			<canvas class="twinkling-stars"></canvas>
			<div class="content">
				<Nav />
				<slot />
				<Footer />
			</div>
		</div>

		<!--
			Turbulence displacement filter for the "liquid drain" section transition. It's
			referenced by ::view-transition-old/new(root) in transitions.css to warp the draining
			page like fluid. Lives here so it exists in the live document during the swap.
		-->
		<svg class="liquid-defs" width="0" height="0" aria-hidden="true" focusable="false">
			<defs>
				<filter id="liquid-drain" x="-30%" y="-30%" width="160%" height="160%" color-interpolation-filters="sRGB">
					<feTurbulence type="fractalNoise" baseFrequency="0.009 0.013" numOctaves="2" seed="7" result="noise">
						<animate attributeName="baseFrequency" dur="7s" values="0.009 0.013;0.013 0.02;0.009 0.013" repeatCount="indefinite" />
					</feTurbulence>
					<!-- scale starts at 0 (crisp page) and is ramped up during the drain by
					     section-transition.ts, so the "goo-ification" builds gradually. -->
					<feDisplacementMap id="liquid-disp" in="SourceGraphic" in2="noise" scale="0" xChannelSelector="R" yChannelSelector="G" />
				</filter>
			</defs>
		</svg>

		<script>
			import '../scripts/photo-section-snap';
			import '../scripts/section-transition';
			import '../scripts/sky';
			import '../scripts/motion';
		</script>

		<style>
			/* --- Atmosphere --- */
			/* The sky is now fully procedural: a per-palette OKLCH gradient mesh
			   (--bg-mesh in tokens.css) under the film-grain noise tile, with the
			   canvas painting stars/clouds above. No more JPEG background stack. */
			.backgrounds {
				min-height: 100%;
				isolation: isolate;
				position: relative;
				background:
					/*noise*/ url('/assets/backgrounds/noise.png') top center/220px repeat,
					/*mesh*/ var(--bg-mesh, none),
					/*base*/ var(--gray-999);
				/* --bg-mesh expands to four gradient layers; blend-mode lists repeat
				   cyclically, so pad with explicit normals to keep overlay on the
				   noise tile only. */
				background-blend-mode: overlay, normal, normal, normal, normal;
			}

			/* Editorial theme: clean paper (--bg-mesh is none there, but keep the
			   hard override so the noise tile also disappears). */
			html[data-section='photography'] .backgrounds {
				background: var(--gray-999);
				background-blend-mode: normal;
			}

			/* --- Canvas Styles for Stars & Meteors --- */
			.twinkling-stars {
				position: fixed;
				inset: 0;
				width: 100%;
				height: 100vh;
				pointer-events: none;
				z-index: 1;
				transition: opacity 600ms ease;
			}

			/* Stars fade out in the editorial world; the renderer pauses there too. */
			html[data-section='photography'] .twinkling-stars {
				opacity: 0;
			}

			.liquid-defs {
				position: absolute;
				width: 0;
				height: 0;
				overflow: hidden;
			}

			/* Ensure main content appears above the canvas */
			.content {
				position: relative;
				z-index: 2;
			}

			@media (forced-colors: active) {
				.backgrounds {
					background: none;
					background-blend-mode: none;
					--bg-gradient-size: none;
				}
			}
		</style>
	</body>
</html>
