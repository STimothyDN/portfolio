---
// Learn about using Astro layouts:
// https://docs.astro.build/en/core-concepts/layouts/

// Component Imports
import MainHead from '../components/MainHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title?: string | undefined;
	description?: string | undefined;
}

const { title, description } = Astro.props;

// Which "world" is this page in? The photography section gets the editorial
// theme (see global.css `html[data-section="photography"]`). Computed server-side
// so the correct theme is applied on direct load / no-JS, and travels with each
// route's HTML across ClientRouter swaps.
const path = Astro.url.pathname;
const section =
	path === '/photography' || path.startsWith('/photography/') ? 'photography' : 'default';
---

<html lang="en" data-section={section}>
	<head>
		<MainHead title={title} description={description} />
	</head>
	<body>
		<!--
			The canvas element renders ambient sky effects: clouds in light mode and
			stars/meteors in dark mode. The page content is wrapped in .content so it appears above.
			The canvas is intentionally NOT persisted: on a section transition we want it
			captured in the View Transition snapshot so it drains away with the page.
		-->
		<div class="stack backgrounds">
			<canvas class="twinkling-stars"></canvas>
			<div class="content">
				<Nav />
				<slot />
				<Footer />
			</div>
		</div>

		<!--
			Turbulence displacement filter for the "liquid drain" section transition. It's
			referenced by ::view-transition-old/new(root) in global.css to warp the draining
			page like fluid. Lives here so it exists in the live document during the swap.
		-->
		<svg class="liquid-defs" width="0" height="0" aria-hidden="true" focusable="false">
			<defs>
				<filter id="liquid-drain" x="-30%" y="-30%" width="160%" height="160%" color-interpolation-filters="sRGB">
					<feTurbulence type="fractalNoise" baseFrequency="0.009 0.013" numOctaves="2" seed="7" result="noise">
						<animate attributeName="baseFrequency" dur="7s" values="0.009 0.013;0.013 0.02;0.009 0.013" repeatCount="indefinite" />
					</feTurbulence>
					<!-- scale starts at 0 (crisp page) and is ramped up during the drain by
					     section-transition.ts, so the "goo-ification" builds gradually. -->
					<feDisplacementMap id="liquid-disp" in="SourceGraphic" in2="noise" scale="0" xChannelSelector="R" yChannelSelector="G" />
				</filter>
			</defs>
		</svg>

		<script>
			import '../scripts/section-transition';
			import '../scripts/soft-stars';
		</script>

		<script is:inline>
			// Add “loaded” class once the document has completely loaded.
			addEventListener('load', () => document.documentElement.classList.add('loaded'));
		</script>

		<style>
			/* --- Existing Background Variables & Styles --- */
			:root {
				--_placeholder-bg: linear-gradient(transparent, transparent);
				--bg-image-main: url('/assets/backgrounds/bg-main-light-800w.jpg');
				--bg-image-main-curves: url('/assets/backgrounds/bg-main-light.svg');
				--bg-image-subtle-1: var(--_placeholder-bg);
				--bg-image-subtle-2: var(--_placeholder-bg);
				--bg-image-footer: var(--_placeholder-bg);
				--bg-svg-blend-mode: overlay;
				--bg-blend-mode: darken;
				--bg-image-aspect-ratio: 2.25;
				--bg-scale: 1.68;
				--bg-aspect-ratio: calc(var(--bg-image-aspect-ratio) / var(--bg-scale));
				--bg-gradient-size: calc(var(--bg-scale) * 100%);
			}

			:root.theme-dark {
				--bg-image-main: url('/assets/backgrounds/bg-main-dark-800w.jpg');
				--bg-image-main-curves: url('/assets/backgrounds/bg-main-dark.svg');
				--bg-svg-blend-mode: darken;
				--bg-blend-mode: lighten;
			}

			:root.loaded {
				--bg-image-subtle-1: url('/assets/backgrounds/bg-subtle-1-light-800w.jpg');
				--bg-image-subtle-2: url('/assets/backgrounds/bg-subtle-2-light-800w.jpg');
				--bg-image-footer: url('/assets/backgrounds/bg-footer-light-800w.jpg');
			}
			:root.loaded.theme-dark {
				--bg-image-subtle-1: url('/assets/backgrounds/bg-subtle-1-dark-800w.jpg');
				--bg-image-subtle-2: url('/assets/backgrounds/bg-subtle-2-dark-800w.jpg');
				--bg-image-footer: url('/assets/backgrounds/bg-footer-dark-800w.jpg');
			}

			@media (min-width: 50em) {
				:root {
					--bg-scale: 1;
					--bg-image-main: url('/assets/backgrounds/bg-main-light-1440w.jpg');
				}
				:root.theme-dark {
					--bg-image-main: url('/assets/backgrounds/bg-main-dark-1440w.jpg');
				}

				:root.loaded {
					--bg-image-subtle-1: url('/assets/backgrounds/bg-subtle-1-light-1440w.jpg');
					--bg-image-subtle-2: url('/assets/backgrounds/bg-subtle-2-light-1440w.jpg');
					--bg-image-footer: url('/assets/backgrounds/bg-footer-light-1440w.jpg');
				}
				:root.loaded.theme-dark {
					--bg-image-subtle-1: url('/assets/backgrounds/bg-subtle-1-dark-1440w.jpg');
					--bg-image-subtle-2: url('/assets/backgrounds/bg-subtle-2-dark-1440w.jpg');
					--bg-image-footer: url('/assets/backgrounds/bg-footer-dark-1440w.jpg');
				}
			}

			/* --- .backgrounds Container Styles --- */
			.backgrounds {
				min-height: 100%;
				isolation: isolate;
				position: relative;
				background:
					/*noise*/ url('/assets/backgrounds/noise.png') top center/220px repeat,
					/*footer*/ var(--bg-image-footer) bottom center/var(--bg-gradient-size) no-repeat,
					/*header1*/ var(--bg-image-main-curves) top center/var(--bg-gradient-size) no-repeat,
					/*header2*/ var(--bg-image-main) top center/var(--bg-gradient-size) no-repeat,
					/*base*/ var(--gray-999);
				background-blend-mode: overlay, var(--bg-blend-mode), var(--bg-svg-blend-mode), normal, normal;
			}

			/* --- Editorial theme: neutralize the space imagery --- */
			/* `:root[...]` (0,2,0) + source order beats `:root.theme-dark` (0,2,0). */
			:root[data-section='photography'] {
				--bg-image-main: none;
				--bg-image-main-curves: none;
				--bg-image-subtle-1: none;
				--bg-image-subtle-2: none;
				--bg-image-footer: none;
				--bg-blend-mode: normal;
				--bg-svg-blend-mode: normal;
			}
			html[data-section='photography'] .backgrounds {
				background: var(--gray-999);
				background-blend-mode: normal;
			}

			/* --- Canvas Styles for Stars & Meteors --- */
			.twinkling-stars {
				position: fixed;
				inset: 0;
				width: 100%;
				height: 100vh;
				pointer-events: none;
				z-index: 1;
				transition: opacity 600ms ease;
			}

			/* Stars fade out in the editorial world; the renderer pauses there too. */
			html[data-section='photography'] .twinkling-stars {
				opacity: 0;
			}

			.liquid-defs {
				position: absolute;
				width: 0;
				height: 0;
				overflow: hidden;
			}

			/* Ensure main content appears above the canvas */
			.content {
				position: relative;
				z-index: 2;
			}

			@media (forced-colors: active) {
				.backgrounds {
					background: none;
					background-blend-mode: none;
					--bg-gradient-size: none;
				}
			}
		</style>
	</body>
</html>
