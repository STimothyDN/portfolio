---
/*
 * The persistent "section frame" for a nested shoot page: the photography
 * masthead reduced to a slim breadcrumb, pinned at the very top with the shoot
 * nested beneath it. Clicking it returns to the section index. Because
 * navigating within /photography is a plain fade (no liquid drain), rendering
 * this bar in the same spot on every shoot makes the section feel like one app
 * whose frame stays put while the shoot content swaps underneath.
 */
import Icon from './Icon.astro';
---

<div class="photo-parent-bar" data-photo-parent-bar transition:persist="photo-parent-bar">
	<div class="pp-inner wrapper">
		<a class="pp-back-link" href="/photography/"><Icon icon="arrow-left" size="1em" /> All shoots</a>
		<p class="pp-kicker">
			<span class="pp-title">Timo From 3,</span>
			<span class="pp-tagline">He shoots! He-</span>
		</p>
	</div>
</div>

<style>
	.photo-parent-bar {
		position: sticky;
		top: 0;
		z-index: 5;
		background: var(--gray-999);
		border-bottom: 1px solid var(--gray-800);
		overflow-anchor: none;
	}

	.pp-inner {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.35rem;
		padding-block: 0.65rem 0.75rem;
	}

	.pp-back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--gray-300);
		font-size: var(--text-sm);
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition:
			color var(--theme-transition),
			text-decoration-color var(--theme-transition);
	}

	.pp-back-link:hover,
	.pp-back-link:focus-visible {
		color: var(--gray-0);
		text-decoration-color: currentColor;
	}

	.pp-kicker {
		display: flex;
		align-items: baseline;
		flex-wrap: wrap;
		gap: 0.35rem 0.5rem;
	}

	.pp-title {
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		font-weight: 500;
		color: var(--gray-300);
	}

	.pp-tagline {
		font-size: var(--text-sm);
		color: var(--gray-400);
	}

	.pp-tagline::before {
		content: '·';
		margin-inline-end: 0.5rem;
		color: var(--gray-400);
	}

	.pp-back-link:focus-visible {
		outline: 2px solid var(--accent-regular);
		outline-offset: 3px;
	}
</style>
