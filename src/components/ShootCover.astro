---
import type { CollectionEntry } from 'astro:content';

import { bunnyImageUrl, bunnySrcSet } from '../utils/bunny';

interface Props {
	shoot: CollectionEntry<'photography'>;
	eager?: boolean;
}

const { shoot, eager = false } = Astro.props;
const { data, id } = shoot;

const cover = data.photos.find((p) => p.filename === data.coverPhoto) ?? data.photos[0];
const src = bunnyImageUrl(id, cover.filename, { width: 1200, format: 'webp', quality: 80 });
const srcset = bunnySrcSet(id, cover.filename, [800, 1200, 1600, 2000], {
	format: 'webp',
	quality: 80,
});
const aspect = cover.width && cover.height ? `${cover.width} / ${cover.height}` : undefined;
const alt = cover.caption || `Cover photo from ${data.title}`;

const formattedDate = data.date.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
	timeZone: 'UTC',
});
---

<article class="shoot-row" data-animate="fade">
	<span class="rule" aria-hidden="true"></span>
	<div class="label">
		<h2 class="title"><a href={`/photography/${id}`} data-shoot-open={id}>{data.title}</a></h2>
		<p class="meta">
			<time datetime={data.date.toISOString().slice(0, 10)}>{formattedDate}</time>
			{data.location && <> · {data.location}</>} · {data.photos.length} photos
		</p>
		{data.description && <p class="description">{data.description}</p>}
	</div>
	<div class="frame">
		<img
			src={src}
			srcset={srcset}
			sizes="(min-width: 50em) 24rem, calc(100vw - 3rem)"
			alt={alt}
			style={aspect ? `aspect-ratio: ${aspect};` : undefined}
			loading={eager ? 'eager' : 'lazy'}
			fetchpriority={eager ? 'high' : undefined}
			decoding="async"
		/>
	</div>
</article>

<style>
	.shoot-row {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		padding-block: 2rem;
	}

	.frame {
		position: relative;
		aspect-ratio: 3 / 2;
		overflow: hidden;
		background: var(--gray-900);
		border: 1px solid var(--gray-800);
	}

	.frame img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* Top rule as a real element so motion.ts can draw it in (scaleX). */
	.rule {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 1px;
		background: var(--gray-800);
		transform-origin: left center;
	}

	.title {
		font-size: clamp(var(--text-xl), 3.5vw, var(--text-3xl));
		line-height: 1.15;
	}

	.title a {
		display: inline-block;
		color: var(--gray-0);
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.2em;
		transition: text-decoration-color var(--theme-transition);
	}

	/* Stretch the title link over the whole plate so anywhere is clickable,
	   while the accessible name stays just the title. */
	.title a::after {
		content: '';
		position: absolute;
		inset: 0;
	}

	.meta {
		margin-top: 0.35rem;
		font-size: var(--text-sm);
		letter-spacing: 0.08em;
		/* Real small caps from the Newsreader variable face (was text-transform:
		 * uppercase before the serif upgrade). */
		font-variant-caps: all-small-caps;
		/* --gray-400 fails 4.5:1 on the photography-light palette; --gray-300 clears it. */
		color: var(--gray-300);
	}

	.description {
		max-width: 60ch;
		margin-top: 0.75rem;
		color: var(--gray-300);
	}

	.shoot-row:hover .title a,
	.shoot-row:has(a:focus-visible) .title a {
		text-decoration-color: currentColor;
	}

	.shoot-row:has(a:focus-visible) {
		outline: 2px solid var(--accent-regular);
		outline-offset: 6px;
	}

	/* Replaced by the plate-level ring above. */
	.title a:focus-visible {
		outline: none;
	}

	@media (prefers-reduced-motion: no-preference) {
		.frame img {
			transition: transform 600ms cubic-bezier(0.33, 1, 0.68, 1);
		}

		.shoot-row:hover .frame img,
		.shoot-row:has(a:focus-visible) .frame img {
			transform: scale(1.02);
		}
	}

	@media (min-width: 50em) {
		.shoot-row {
			display: grid;
			grid-template-columns: minmax(0, 1fr) minmax(16rem, 24rem);
			gap: 2rem;
			align-items: center;
			padding-block: 2.75rem;
		}
	}

	@media (min-width: 50em) and (pointer: fine) and (prefers-reduced-motion: no-preference) and (scripting: enabled) {
		.shoot-row {
			grid-template-columns: minmax(0, 1fr);
		}

		.frame {
			display: none;
		}

		.shoot-row:has(a:focus-visible) {
			grid-template-columns: minmax(0, 1fr) minmax(16rem, 24rem);
		}

		.shoot-row:has(a:focus-visible) .frame {
			display: block;
		}
	}
</style>
