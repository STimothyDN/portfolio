---
import type { CollectionEntry } from 'astro:content';

import { bunnyImageUrl, bunnySrcSet } from '../utils/bunny';

interface Props {
	shoot: CollectionEntry<'photography'>;
	eager?: boolean;
}

const { shoot, eager = false } = Astro.props;
const { data, id } = shoot;

const cover = data.photos.find((p) => p.filename === data.coverPhoto) ?? data.photos[0];
const src = bunnyImageUrl(id, cover.filename, { width: 1200, format: 'webp', quality: 80 });
const srcset = bunnySrcSet(id, cover.filename, [800, 1200, 1600, 2000], {
	format: 'webp',
	quality: 80,
});
const aspect = cover.width && cover.height ? `${cover.width} / ${cover.height}` : undefined;
const alt = cover.caption || `Cover photo from ${data.title}`;

const formattedDate = data.date.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
	timeZone: 'UTC',
});
---

<article class="plate">
	<div class="frame">
		<img
			src={src}
			srcset={srcset}
			sizes="(min-width: 50em) min(60rem, 80vw), calc(100vw - 3rem)"
			alt={alt}
			style={aspect ? `aspect-ratio: ${aspect};` : undefined}
			loading={eager ? 'eager' : 'lazy'}
			fetchpriority={eager ? 'high' : undefined}
			decoding="async"
		/>
	</div>
	<div class="label">
		<h2 class="title"><a href={`/photography/${id}`} data-shoot-open={id}>{data.title}</a></h2>
		<p class="meta">
			<time datetime={data.date.toISOString().slice(0, 10)}>{formattedDate}</time>
			{data.location && <> · {data.location}</>} · {data.photos.length} photos
		</p>
		{data.description && <p class="description">{data.description}</p>}
	</div>
</article>

<style>
	.plate {
		position: relative;
	}

	.frame {
		overflow: hidden;
		background: var(--gray-900);
		border: 1px solid var(--gray-800);
	}

	.frame img {
		display: block;
		width: 100%;
		height: auto;
		max-height: 75svh;
		object-fit: cover;
	}

	.label {
		margin-top: 1rem;
		padding-top: 0.85rem;
		border-top: 1px solid var(--gray-800);
	}

	.title {
		font-size: clamp(var(--text-xl), 3.5vw, var(--text-3xl));
		line-height: 1.15;
	}

	.title a {
		color: var(--gray-0);
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.2em;
		transition: text-decoration-color var(--theme-transition);
	}

	/* Stretch the title link over the whole plate so anywhere is clickable,
	   while the accessible name stays just the title. */
	.title a::after {
		content: '';
		position: absolute;
		inset: 0;
	}

	.meta {
		margin-top: 0.35rem;
		font-size: var(--text-sm);
		letter-spacing: 0.06em;
		text-transform: uppercase;
		/* --gray-400 fails 4.5:1 on the photography-light palette; --gray-300 clears it. */
		color: var(--gray-300);
	}

	.description {
		max-width: 60ch;
		margin-top: 0.75rem;
		color: var(--gray-300);
	}

	.plate:hover .title a,
	.plate:has(a:focus-visible) .title a {
		text-decoration-color: currentColor;
	}

	.plate:has(a:focus-visible) {
		outline: 2px solid var(--accent-regular);
		outline-offset: 6px;
	}

	/* Replaced by the plate-level ring above. */
	.title a:focus-visible {
		outline: none;
	}

	@media (prefers-reduced-motion: no-preference) {
		.frame img {
			transition: transform 600ms cubic-bezier(0.33, 1, 0.68, 1);
		}

		.plate:hover .frame img,
		.plate:has(a:focus-visible) .frame img {
			transform: scale(1.02);
		}
	}
</style>
