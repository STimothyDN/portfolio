---
import '../styles/app.css';

// Self-hosted variable fonts (font-display: swap; downloads only when a
// palette actually uses the face). Space theme: Bricolage Grotesque (display,
// opsz axis) + Instrument Sans (body). Editorial: Fraunces (full axes —
// opsz/SOFT/WONK drive the photography masthead) + Newsreader.
import '@fontsource-variable/bricolage-grotesque/opsz.css';
import '@fontsource-variable/instrument-sans';
import '@fontsource-variable/instrument-sans/wght-italic.css';
import '@fontsource-variable/fraunces/full.css';
import '@fontsource-variable/fraunces/full-italic.css';
import '@fontsource-variable/newsreader/opsz.css';
import '@fontsource-variable/newsreader/opsz-italic.css';

// Hashed URLs for preloading the above-the-fold faces per section.
import bricolageUrl from '@fontsource-variable/bricolage-grotesque/files/bricolage-grotesque-latin-opsz-normal.woff2?url';
import instrumentUrl from '@fontsource-variable/instrument-sans/files/instrument-sans-latin-wght-normal.woff2?url';
import frauncesItalicUrl from '@fontsource-variable/fraunces/files/fraunces-latin-full-italic.woff2?url';
import newsreaderUrl from '@fontsource-variable/newsreader/files/newsreader-latin-opsz-normal.woff2?url';

import { ClientRouter } from 'astro:transitions';

interface Props {
	title?: string | undefined;
	description?: string | undefined;
}

const {
	title = 'Timothy Navarro',
	description = 'The personal portfolio of Timothy Navarro',
} = Astro.props;

// Same section computation as BaseLayout: the editorial faces are only
// above-the-fold inside /photography.
const path = Astro.url.pathname;
const isPhotography = path === '/photography' || path.startsWith('/photography/');
const preloadFonts = isPhotography ? [frauncesItalicUrl, newsreaderUrl] : [bricolageUrl, instrumentUrl];
---

<meta charset="UTF-8" />
<meta name="description" property="og:description" content={description} />
<meta name="viewport" content="width=device-width" />
<meta name="generator" content={Astro.generator} />
<title>{title}</title>

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
{preloadFonts.map((href) => <link rel="preload" as="font" type="font/woff2" href={href} crossorigin />)}

<ClientRouter />

<script is:inline>
	// This code is inlined in the head to make dark mode instant & blocking.
	// One theme for the whole site: saved toggle choice first, then OS preference.
	// (The photography section restyles via its own token palette for each mode —
	// it must not fork the light/dark state itself.)
	const getThemePreference = () => {
		if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
			return localStorage.getItem('theme');
		}
		return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
	};
	const applyTheme = () => {
		const isPhoto = window.location.pathname.startsWith('/photography');
		const isDark = !isPhoto && getThemePreference() === 'dark';
		document.documentElement.classList[isDark ? 'add' : 'remove']('theme-dark');
	};
	applyTheme();

	// Persistence happens only on an explicit toggle click (see ThemeToggle.astro).
	// A MutationObserver on the class attribute used to do it, but it also fired on
	// unrelated class changes (e.g. the `loaded` class), saving the OS-derived mode
	// as if the user had chosen it — which then pinned the site to that mode forever.

	// ClientRouter swaps the <html> attributes on navigation, which drops
	// `theme-dark`; reapply it after every swap. Register once — this `is:inline`
	// script re-executes on every navigation.
	if (!window.__themeObserver) {
		window.__themeObserver = true;
		document.addEventListener('astro:after-swap', applyTheme);
	}
</script>

<script is:inline>
	// Mark the page "animation-ready" BEFORE first paint so the CSS in base.css
	// hides entrance-animated elements up front — otherwise the fully-rendered
	// static HTML flashes for a frame before motion.ts sets its initial states.
	// Only added when JS runs and motion is allowed, so no-JS and reduced-motion
	// visitors always see fully-visible content. motion.ts then reveals it.
	const applyAnimReady = () => {
		const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		document.documentElement.classList.toggle('anim-ready', !reduce);
	};
	applyAnimReady();
	if (!window.__animReadySwap) {
		window.__animReadySwap = true;
		document.addEventListener('astro:after-swap', applyAnimReady);
	}
</script>
