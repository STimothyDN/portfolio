---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
	title?: string | undefined;
	description?: string | undefined;
}

const {
	title = 'Timothy Navarro',
	description = 'The personal portfolio of Timothy Navarro',
} = Astro.props;
---

<meta charset="UTF-8" />
<meta name="description" property="og:description" content={description} />
<meta name="viewport" content="width=device-width" />
<meta name="generator" content={Astro.generator} />
<title>{title}</title>

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
	href="https://fonts.googleapis.com/css2?family=Public+Sans:ital,wght@0,400;0,700;1,400&family=Rubik:wght@500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Tangerine:wght@400;700&display=swap"
	rel="stylesheet"
/>

<ClientRouter />

<script is:inline>
	// This code is inlined in the head to make dark mode instant & blocking.
	// One theme for the whole site: saved toggle choice first, then OS preference.
	// (The photography section restyles via its own token palette for each mode —
	// it must not fork the light/dark state itself.)
	const getThemePreference = () => {
		if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
			return localStorage.getItem('theme');
		}
		return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
	};
	const applyTheme = () => {
		const isDark = getThemePreference() === 'dark';
		document.documentElement.classList[isDark ? 'add' : 'remove']('theme-dark');
	};
	applyTheme();

	// Persistence happens only on an explicit toggle click (see ThemeToggle.astro).
	// A MutationObserver on the class attribute used to do it, but it also fired on
	// unrelated class changes (e.g. the `loaded` class), saving the OS-derived mode
	// as if the user had chosen it — which then pinned the site to that mode forever.

	// ClientRouter swaps the <html> attributes on navigation, which drops
	// `theme-dark`; reapply it after every swap. Register once — this `is:inline`
	// script re-executes on every navigation.
	if (!window.__themeObserver) {
		window.__themeObserver = true;
		document.addEventListener('astro:after-swap', applyTheme);
	}
</script>
