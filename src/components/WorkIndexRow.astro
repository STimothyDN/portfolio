---
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'work'>;
	index: number;
	eager?: boolean;
}

const { project, index, eager = false } = Astro.props;
const { data, slug } = project;
const number = String(index + 1).padStart(2, '0');
const year = data.publishDate.getFullYear();
---

<article class="row">
	<span class="index" aria-hidden="true">{number}</span>
	<div class="text">
		<h2 class="title"><a href={`/work/${slug}`}>{data.title}</a></h2>
		<p class="description">{data.description}</p>
		<p class="meta">
			<span class="year">{year}</span>
			<span class="tags" role="list">
				{data.tags.map((t) => <span role="listitem">{t}</span>)}
			</span>
		</p>
	</div>
	<div class="thumb">
		<img
			src={data.img}
			alt={data.img_alt || ''}
			loading={eager ? 'eager' : 'lazy'}
			fetchpriority={eager ? 'high' : undefined}
			decoding="async"
			transition:name={`work-image-${slug}`}
		/>
	</div>
</article>

<style>
	.row {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		padding-block: 2rem;
		border-top: 1px solid var(--gray-800);
	}

	.index {
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		font-variant-numeric: tabular-nums;
		color: var(--gray-400);
	}

	.text {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.title {
		font-size: clamp(var(--text-2xl), 4.5vw, var(--text-4xl));
		line-height: 1.1;
	}

	.title a {
		color: var(--gray-0);
		text-decoration: none;
		transition: color var(--theme-transition);
	}

	/* Stretch the title link over the whole row so anywhere is clickable,
	   while the accessible name stays just the title. */
	.title a::after {
		content: '';
		position: absolute;
		inset: 0;
	}

	.description {
		max-width: 60ch;
		color: var(--gray-300);
	}

	.meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem 0.75rem;
		font-size: var(--text-sm);
		color: var(--gray-400);
	}

	.tags {
		display: contents;
	}

	/* The year always leads the meta line, so every tag gets a leading dot. */
	.tags span::before {
		content: '·';
		margin-inline-end: 0.75rem;
	}

	.thumb {
		aspect-ratio: 16 / 10;
		overflow: hidden;
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		box-shadow: var(--shadow-sm);
	}

	.thumb img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: saturate(0.55) contrast(0.95);
		opacity: 0.85;
	}

	.row:hover .thumb img,
	.row:has(a:focus-visible) .thumb img {
		filter: none;
		opacity: 1;
		transform: scale(1.04);
	}

	.row:hover .title a,
	.row:has(a:focus-visible) .title a {
		color: var(--accent-dark);
	}

	.row:has(a:focus-visible) {
		outline: 2px solid var(--accent-dark);
		outline-offset: 4px;
	}

	/* Replaced by the row-level ring above. */
	.title a:focus-visible {
		outline: none;
	}

	@media (prefers-reduced-motion: no-preference) {
		.thumb img {
			transition:
				transform 400ms cubic-bezier(0.33, 1, 0.68, 1),
				filter var(--theme-transition),
				opacity var(--theme-transition);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.thumb img,
		.row:hover .thumb img,
		.row:has(a:focus-visible) .thumb img {
			transform: none;
		}
	}

	@media (min-width: 50em) {
		.row {
			display: grid;
			grid-template-columns: 3.5rem 1fr 18rem;
			gap: 2rem;
			align-items: center;
			padding-block: 3rem;
		}

		.thumb {
			aspect-ratio: 3 / 2;
		}
	}
</style>
