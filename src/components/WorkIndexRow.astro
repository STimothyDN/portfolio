---
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'work'>;
	eager?: boolean;
}

const { project, eager = false } = Astro.props;
const { data, slug } = project;
const year = data.publishDate.getFullYear();
---

<article class="row" data-slug={slug}>
	<span class="hairline" aria-hidden="true"></span>
	<h2 class="title"><a href={`/work/${slug}`} transition:name={`work-title-${slug}`}>{data.title}</a></h2>
	<div class="thumb">
		<img
			src={data.img}
			alt={data.img_alt || ''}
			loading={eager ? 'eager' : 'lazy'}
			fetchpriority={eager ? 'high' : undefined}
			decoding="async"
			transition:name={`work-image-${slug}`}
		/>
		<div class="thumb-overlay">
			<p class="preview-year" data-preview-vt={`work-year-${slug}`}>{year}</p>
			<div class="preview-tags" role="list">
				{data.tags.map((t, i) => <span role="listitem" data-preview-vt={`work-tag-${slug}-${i}`}>{t}</span>)}
			</div>
			<p class="preview-description" data-preview-vt={`work-description-${slug}`}>{data.description}</p>
		</div>
	</div>
</article>

<style>
	.row {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		padding-block: 2rem;
	}

	/* Top rule as a real element (not border) so motion.ts can scaleX-reveal it. */
	.hairline {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 1px;
		background: var(--gray-800);
		transform-origin: left center;
	}

	.title {
		font-size: clamp(var(--text-2xl), 4.5vw, var(--text-4xl));
		line-height: 1.1;
	}

	.title a {
		display: inline-block;
		color: var(--gray-0);
		text-decoration: none;
		transition: color var(--theme-transition);
	}

	/* Stretch the title link over the whole row so anywhere is clickable,
	   while the accessible name stays just the title. */
	.title a::after {
		content: '';
		position: absolute;
		inset: 0;
	}

	.thumb {
		position: relative;
		aspect-ratio: 16 / 10;
		overflow: hidden;
		border: 1px solid var(--gray-800);
		border-radius: 0.5rem;
		box-shadow: var(--shadow-sm);
		background: var(--gray-999);
	}

	.thumb img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: saturate(0.55) contrast(0.95);
		opacity: 0.85;
	}

	.thumb::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, rgb(0 0 0 / 0.2), rgb(0 0 0 / 0.78));
		pointer-events: none;
	}

	.thumb-overlay {
		position: absolute;
		inset: auto 0 0;
		z-index: 1;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: clamp(1rem, 4vw, 1.5rem);
		color: white;
		text-shadow: 0 1px 1.5rem rgb(0 0 0 / 0.45);
	}

	.preview-year {
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		font-variant-numeric: tabular-nums;
		color: rgb(255 255 255 / 0.72);
	}

	.preview-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.preview-tags span {
		display: inline-flex;
		align-items: center;
		min-height: 1.85rem;
		padding: 0.3rem 0.65rem;
		border: 1px solid rgb(255 255 255 / 0.32);
		border-radius: 999rem;
		background: rgb(0 0 0 / 0.28);
		font-size: var(--text-sm);
		line-height: 1.2;
		backdrop-filter: blur(10px);
	}

	.preview-description {
		display: -webkit-box;
		overflow: hidden;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 3;
		max-width: 52ch;
		font-size: var(--text-md);
		line-height: 1.45;
		color: rgb(255 255 255 / 0.9);
	}

	.row:hover .thumb img,
	.row:has(a:focus-visible) .thumb img {
		filter: none;
		opacity: 1;
		transform: scale(1.04);
	}

	.row:hover .title a,
	.row:has(a:focus-visible) .title a {
		color: var(--accent-dark);
	}

	.row:has(a:focus-visible) {
		outline: 2px solid var(--accent-dark);
		outline-offset: 4px;
	}

	/* Replaced by the row-level ring above. */
	.title a:focus-visible {
		outline: none;
	}

	@media (prefers-reduced-motion: no-preference) {
		.thumb img {
			transition:
				transform 400ms cubic-bezier(0.33, 1, 0.68, 1),
				filter var(--theme-transition),
				opacity var(--theme-transition);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.thumb img,
		.row:hover .thumb img,
		.row:has(a:focus-visible) .thumb img {
			transform: none;
		}
	}

	@media (min-width: 50em) {
		.row {
			display: grid;
			grid-template-columns: minmax(0, 1fr) 18rem;
			gap: 2rem;
			align-items: center;
			padding-block: 3rem;
		}

		.thumb {
			aspect-ratio: 3 / 2;
		}
	}

	/* Cursor-follow mode (work-hover.ts): the static thumb column collapses and
	 * a floating preview tracks the pointer. The media query must match the JS
	 * gate exactly — coarse pointers and reduced-motion users keep this column,
	 * and (scripting: enabled) keeps thumbs for no-JS visitors since the
	 * follower can't run there. Keyboard focus always brings the static thumb
	 * back (the follower never responds to focus). */
	@media (min-width: 50em) and (pointer: fine) and (prefers-reduced-motion: no-preference) and (scripting: enabled) {
		/* Collapse the reserved thumb column so the text spans the row; the
		 * floating follower carries the preview instead. */
		.row {
			grid-template-columns: minmax(0, 1fr);
		}

		.thumb {
			display: none;
		}

		/* Keyboard focus restores the static thumb in its own column. */
		.row:has(a:focus-visible) {
			grid-template-columns: minmax(0, 1fr) 18rem;
		}

		.row:has(a:focus-visible) .thumb {
			display: block;
		}
	}
</style>
